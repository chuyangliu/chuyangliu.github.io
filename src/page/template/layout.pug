block var
  -
    const cfg = {
      title: '',
      highlightjs: false,
      mathjax: false,
    }

mixin head()
  meta(charset='utf-8')
  meta(name='viewport', content='width=device-width, initial-scale=1')

  block meta

  if cfg.title === ''
    title Chuyang Liu
  else
    title #{cfg.title} - Chuyang Liu

  link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/bootstrap@3.3.7/dist/css/bootstrap.min.css',
       integrity='sha384-BVYiiSIFeK1dGmJRAkycuHAHRg32OmUcww7on3RYdg4Va+PmSTsz/K68vbdEjh4u', crossorigin='anonymous')

  if cfg.highlighjs
    link(rel='stylesheet', href='https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.5.1/styles/base16/equilibrium-light.min.css',
         integrity='sha512-NP+owW/oTQAAi/rS9vG0BoI9YsEx2TV/RMyu/Q1TALUyQuH7LKARCv7LYIDUZYf6j8ZjVESmHCZlI6i2xTun0Q==' crossorigin='anonymous')

  block style

  script(src='https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js',
         integrity='sha512-894YE6QWD5I59HgZOGReFYm4dnWc1Qt5NtvYSaNcOP+u1T9qYdvdihz0PPSiiqn/+/3e7Jo4EaG7TubfWGUrMQ==', crossorigin='anonymous')

  script(src='https://cdn.jsdelivr.net/npm/bootstrap@3.3.7/dist/js/bootstrap.min.js',
         integrity='sha384-Tc5IQib027qvyjSMfHjOMaLkfuWVxZxUPnCJA7l2mCWNIpG9mGCD8wGNIcPD7Txa', crossorigin='anonymous')

  if cfg.highlighjs
    script(src='https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.5.1/highlight.min.js',
           integrity='sha512-yUUc0qWm2rhM7X0EFe82LNnv2moqArj5nro/w1bi05A09hRVeIZbN6jlMoyu0+4I/Bu4Ck/85JQIU82T82M28w==', crossorigin='anonymous')

  if cfg.mathjax
    script(async, src='https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.7/MathJax.js?config=TeX-MML-AM_CHTML',
           integrity='sha512-Fv0JVzxvrWFLhiUP8wZYR6VwBZQt0XqB9MhHZE+12lObqIDzg3LOJcCCiRy6g4MCX/MlG+R9IRCWZAHjo9iBgw==', crossorigin='anonymous')

  block script

mixin body()
  .container
    .row
      .col-sm-1
      .col-sm-10
        if cfg.title !== ''
          h1 #{cfg.title}
          hr
        block content
        if cfg.title === ''
          include footer/min.pug
        else
          include footer/full.pug
      .col-sm-1

doctype html
html(lang='en')
  head
    +head()
  body
    +body()
