extends template/layout.pug

block style
  link(rel='stylesheet', href='/style/index.css')

block script
  script(src='/script/index.js')

block content
  include /markdown/index.html

  form.form-inline
    .form-group
      label.sr-only(for='command')
      input.form-control(type='text', id='command', placeholder='Type any command')
    button(type='submit', id='run', class='btn btn-danger') Run

  samp#output
