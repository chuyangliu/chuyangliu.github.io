{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true,
    "jquery": true
  },
  "extends": [
    "airbnb-base"
  ],
  "parserOptions": {
    "ecmaVersion": 12
  },
  "rules": {
    "max-len": ["error", {
      "code": 140
    }],
    "no-param-reassign": ["error", {
      "props": false
    }]
  }
}
